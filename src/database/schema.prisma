datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id              String      @id @default(uuid())
  externalId      String?     @unique // CRM ID
  firstName       String?
  lastName        String?
  email           String?     @unique
  phone           String?     @unique
  company         String?
  jobTitle        String?
  industry        String?
  budget          Float?
  urgency         String?     // HIGH, MEDIUM, LOW
  authorityLevel  String?     // DECISION_MAKER, INFLUENCER, etc.
  leadScore       Float       @default(0)
  status          LeadStatus  @default(NEW)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  interactions    Interaction[]
  memories        Memory[]
}

model Interaction {
  id              String      @id @default(uuid())
  leadId          String
  lead            Lead        @relation(fields: [leadId], references: [id])
  type            InteractionType
  direction       String      // INBOUND, OUTBOUND
  duration        Int?        // In seconds
  transcript      String?     @map("text_content")
  sentimentScore  Float?
  outcome         String?     // QUALIFIED, DISQUALIFIED, ESCALATED, BOOKED
  metadata        String?     // JSON string for additional data
  createdAt       DateTime    @default(now())
}

model Memory {
  id              String      @id @default(uuid())
  leadId          String
  lead            Lead        @relation(fields: [leadId], references: [id])
  key             String
  value           String
  type            MemoryType  @default(PERSISTED)
  updatedAt       DateTime    @updatedAt
}

enum LeadStatus {
  NEW
  QUALIFYING
  QUALIFIED
  NURTURING
  BOOKED
  ESCAlATED
  DISQUALIFIED
}

enum InteractionType {
  VOICE_CALL
  SMS
  EMAIL
  FORM_SUBMISSION
}

enum MemoryType {
  SESSION
  PERSISTED
}
